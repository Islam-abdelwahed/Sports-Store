@model Project.Models.CategoryVM

@{
    ViewData["Title"] = "Create Category";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4><i class="bi bi-plus-circle"></i> Create New Category</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ParentCategoryId" class="form-label"></label>
                        <select asp-for="ParentCategoryId" asp-items="@(new SelectList(Model.ParentCategories, "CategoryId", "Name"))" class="form-select">
                            <option value="">-- Main Category (No Parent) --</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-success">Create Category</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}