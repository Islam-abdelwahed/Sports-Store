@model Project.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h4><i class="bi bi-trash"></i> Delete Confirmation</h4>
            </div>
            <div class="card-body">
                <h5>Are you sure you want to delete this product?</h5>
                <div class="alert alert-danger">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Product Name:</dt>
                        <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

                        <dt class="col-sm-4">SKU:</dt>
                        <dd class="col-sm-8">@Model.SKU</dd>

                        <dt class="col-sm-4">Price:</dt>
                        <dd class="col-sm-8">$@Model.Price.ToString("N2")</dd>

                        <dt class="col-sm-4">Stock:</dt>
                        <dd class="col-sm-8">@Model.StockQuantity units</dd>
                    </dl>
                </div>

                @if (ViewBag.HasOrders)
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i>
                        This product appears in <strong>@ViewBag.OrderItemCount order item(s)</strong>.
                        It will be <strong>deactivated</strong> (soft-deleted) instead of permanently removed to preserve order history.
                    </div>
                }

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="ProductId" />
                    @if (ViewBag.HasOrders)
                    {
                        <button type="submit" class="btn btn-warning">Yes, Deactivate</button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    }
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
