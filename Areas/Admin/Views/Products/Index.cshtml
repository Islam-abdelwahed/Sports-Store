@model Project.Models.PaginatedResult<Project.Models.ProductVM>

@{
    ViewData["Title"] = "Manage Products";
    var filters = (Project.Models.ProductFilterOptions?)ViewData["CurrentFilters"] ?? new Project.Models.ProductFilterOptions();
    var categories = (IEnumerable<Project.Models.CategoryVM>?)ViewData["Categories"] ?? new List<Project.Models.CategoryVM>();
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="bi bi-box-seam"></i> Products</h4>
        <a asp-action="Create" class="btn btn-light btn-sm">
            <i class="bi bi-plus-circle"></i> New Product
        </a>
    </div>
    <div class="card-body">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Filter Bar -->
        <form asp-action="Index" method="get" class="mb-3">
            <div class="row g-2 mb-3">
                <div class="col-md-3">
                    <input type="text" name="SearchTerm" class="form-control form-control-sm" placeholder="Search by name or SKU..." value="@filters.SearchTerm" />
                </div>
                <div class="col-md-2">
                    <select name="CategoryId" class="form-select form-select-sm">
                        <option value="">All Categories</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category.CategoryId" selected="@(filters.CategoryId == category.CategoryId)">@category.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="IsActive" class="form-select form-select-sm">
                        <option value="">All Status</option>
                        <option value="true" selected="@(filters.IsActive == true)">Active</option>
                        <option value="false" selected="@(filters.IsActive == false)">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="InStockOnly" id="inStockOnly" value="true" checked="@filters.InStockOnly" />
                        <label class="form-check-label form-check-label-sm" for="inStockOnly">In Stock Only</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </div>

            <div class="row g-2 align-items-center">
                <div class="col-md-6">
                    @if (filters.HasActiveFilters || filters.CategoryId.HasValue || filters.IsActive.HasValue || filters.InStockOnly == true)
                    {
                        <a asp-action="Index" class="btn btn-secondary btn-sm">
                            <i class="bi bi-x"></i> Clear All Filters
                        </a>
                        <span class="text-muted ms-2">Filters active</span>
                    }
                </div>
                <div class="col-md-3">
                    <select name="SortBy" class="form-select form-select-sm">
                        <option value="">Sort By</option>
                        <option value="Name" selected="@(filters.SortBy == "Name")">Name</option>
                        <option value="Price" selected="@(filters.SortBy == "Price")">Price</option>
                        <option value="Stock" selected="@(filters.SortBy == "Stock")">Stock Quantity</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="PageSize" class="form-select form-select-sm">
                        <option value="10" selected="@(filters.PageSize == 10)">10 per page</option>
                        <option value="25" selected="@(filters.PageSize == 25)">25 per page</option>
                        <option value="50" selected="@(filters.PageSize == 50)">50 per page</option>
                        <option value="100" selected="@(filters.PageSize == 100)">100 per page</option>
                    </select>
                </div>
            </div>
        </form>

        <!-- Results Info -->
        <div class="mb-3 text-muted small">
            <i class="bi bi-info-circle"></i>
            Showing @Model.FirstItemNumber to @Model.LastItemNumber of <strong>@Model.TotalItems</strong> products
        </div>

        <!-- Table -->
        @if (Model.Items.Any())
        {
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>SKU</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><strong>@item.ProductId</strong></td>
                            <td>@item.Name</td>
                            <td><code>@item.SKU</code></td>
                            <td>@item.CategoryName</td>
                            <td><strong>$@item.Price.ToString("N2")</strong></td>
                            <td>
                                @if (item.StockQuantity > 10)
                                {
                                    <span class="badge bg-success">@item.StockQuantity</span>
                                }
                                else if (item.StockQuantity > 0)
                                {
                                    <span class="badge bg-warning text-dark">@item.StockQuantity</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Out of Stock</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Product pagination" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                    { "SearchTerm", filters.SearchTerm ?? "" },
                                    { "CategoryId", filters.CategoryId?.ToString() ?? "" },
                                    { "IsActive", filters.IsActive?.ToString() ?? "" },
                                    { "InStockOnly", filters.InStockOnly?.ToString() ?? "" },
                                    { "SortBy", filters.SortBy ?? "" },
                                    { "PageNumber", "1" },
                                    { "PageSize", filters.PageSize.ToString() }
                                }">
                                    <i class="bi bi-chevron-double-left"></i> First
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                    { "SearchTerm", filters.SearchTerm ?? "" },
                                    { "CategoryId", filters.CategoryId?.ToString() ?? "" },
                                    { "IsActive", filters.IsActive?.ToString() ?? "" },
                                    { "InStockOnly", filters.InStockOnly?.ToString() ?? "" },
                                    { "SortBy", filters.SortBy ?? "" },
                                    { "PageNumber", (Model.CurrentPage - 1).ToString() },
                                    { "PageSize", filters.PageSize.ToString() }
                                }">
                                    <i class="bi bi-chevron-left"></i> Previous
                                </a>
                            </li>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                    { "SearchTerm", filters.SearchTerm ?? "" },
                                    { "CategoryId", filters.CategoryId?.ToString() ?? "" },
                                    { "IsActive", filters.IsActive?.ToString() ?? "" },
                                    { "InStockOnly", filters.InStockOnly?.ToString() ?? "" },
                                    { "SortBy", filters.SortBy ?? "" },
                                    { "PageNumber", i.ToString() },
                                    { "PageSize", filters.PageSize.ToString() }
                                }">@i</a>
                            </li>
                        }

                        @if (Model.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                    { "SearchTerm", filters.SearchTerm ?? "" },
                                    { "CategoryId", filters.CategoryId?.ToString() ?? "" },
                                    { "IsActive", filters.IsActive?.ToString() ?? "" },
                                    { "InStockOnly", filters.InStockOnly?.ToString() ?? "" },
                                    { "SortBy", filters.SortBy ?? "" },
                                    { "PageNumber", (Model.CurrentPage + 1).ToString() },
                                    { "PageSize", filters.PageSize.ToString() }
                                }">
                                    Next <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                    { "SearchTerm", filters.SearchTerm ?? "" },
                                    { "CategoryId", filters.CategoryId?.ToString() ?? "" },
                                    { "IsActive", filters.IsActive?.ToString() ?? "" },
                                    { "InStockOnly", filters.InStockOnly?.ToString() ?? "" },
                                    { "SortBy", filters.SortBy ?? "" },
                                    { "PageNumber", Model.TotalPages.ToString() },
                                    { "PageSize", filters.PageSize.ToString() }
                                }">
                                    Last <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> No products found matching your criteria.
            </div>
        }
    </div>
</div>
