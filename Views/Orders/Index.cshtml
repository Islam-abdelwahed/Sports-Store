@model Project.Models.PaginatedResult<Project.Models.OrderDetailsVM>

@{
    ViewData["Title"] = "My Orders";
    var filters = (Project.Models.OrderFilterOptions?)ViewData["CurrentFilters"] ?? new Project.Models.OrderFilterOptions();
}

<div class="container">
    <h2 class="mb-4"><i class="bi bi-bag-check"></i> My Orders</h2>

    <!-- Filter Bar -->
    <form asp-action="Index" method="get" class="mb-4">
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-2 mb-2">
                    <div class="col-md-3">
                        <input type="text" name="SearchTerm" class="form-control form-control-sm" placeholder="Search by order #..." value="@filters.SearchTerm" />
                    </div>
                    <div class="col-md-2">
                        <select name="OrderStatus" class="form-select form-select-sm">
                            <option value="">All Status</option>
                            <option value="0" selected="@(filters.OrderStatus == 0)">Pending</option>
                            <option value="1" selected="@(filters.OrderStatus == 1)">Processing</option>
                            <option value="2" selected="@(filters.OrderStatus == 2)">Shipped</option>
                            <option value="3" selected="@(filters.OrderStatus == 3)">Delivered</option>
                            <option value="4" selected="@(filters.OrderStatus == 4)">Cancelled</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="date" name="DateFrom" class="form-control form-control-sm" value="@filters.DateFrom?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-2">
                        <input type="date" name="DateTo" class="form-control form-control-sm" value="@filters.DateTo?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </div>

                <div class="row g-2 align-items-center">
                    <div class="col-md-6">
                        @if (filters.HasActiveFilters || filters.OrderStatus.HasValue || filters.DateFrom.HasValue || filters.DateTo.HasValue)
                        {
                            <a asp-action="Index" class="btn btn-secondary btn-sm">
                                <i class="bi bi-x"></i> Clear Filters
                            </a>
                            <span class="text-muted ms-2">Filters active</span>
                        }
                    </div>
                    <div class="col-md-6 text-end">
                        <label for="pageSize" class="me-2">Orders per page:</label>
                        <select name="PageSize" id="pageSize" class="form-select form-select-sm d-inline-block w-auto">
                            <option value="10" selected="@(filters.PageSize == 10)">10</option>
                            <option value="20" selected="@(filters.PageSize == 20)">20</option>
                            <option value="50" selected="@(filters.PageSize == 50)">50</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Items.Any())
    {
        <div class="mb-2 text-muted small">
            <i class="bi bi-info-circle"></i>
            Showing @Model.FirstItemNumber to @Model.LastItemNumber of <strong>@Model.TotalItems</strong> orders
        </div>

        <div class="row">
            @foreach (var order in Model.Items)
            {
                <div class="col-12 mb-3">
                    <div class="card shadow-sm">
                        <div class="card-header bg-light">
                            <div class="row align-items-center">
                                <div class="col-md-3">
                                    <small class="text-muted">Order Number</small><br />
                                    <strong>@order.OrderNumber</strong>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted">Order Date</small><br />
                                    @order.OrderDate.ToString("MMM dd, yyyy")
                                </div>
                                <div class="col-md-2">
                                    <small class="text-muted">Total</small><br />
                                    <strong class="text-success">$@order.TotalAmount.ToString("N2")</strong>
                                </div>
                                <div class="col-md-2">
                                    <small class="text-muted">Status</small><br />
                                    @switch (order.StatusCode)
                                    {
                                        case 0:
                                            <span class="badge bg-warning text-dark">@order.Status</span>
                                            break;
                                        case 1:
                                            <span class="badge bg-info">@order.Status</span>
                                            break;
                                        case 2:
                                            <span class="badge bg-primary">@order.Status</span>
                                            break;
                                        case 3:
                                            <span class="badge bg-success">@order.Status</span>
                                            break;
                                        case 4:
                                            <span class="badge bg-danger">@order.Status</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@order.Status</span>
                                            break;
                                    }
                                </div>
                                <div class="col-md-2 text-end">
                                    <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-primary">
                                        <i class="bi bi-eye"></i> View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <h6 class="mb-2">Order Items (@order.Items.Count)</h6>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var item in order.Items.Take(3))
                                {
                                    <span class="badge bg-secondary">@item.ProductName (x@item.Quantity)</span>
                                }
                                @if (order.Items.Count > 3)
                                {
                                    <span class="badge bg-light text-dark">+@(order.Items.Count - 3) more</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Orders pagination" class="mt-4">
                <ul class="pagination justify-content-center">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                { "SearchTerm", filters.SearchTerm ?? "" },
                                { "OrderStatus", filters.OrderStatus?.ToString() ?? "" },
                                { "DateFrom", filters.DateFrom?.ToString("yyyy-MM-dd") ?? "" },
                                { "DateTo", filters.DateTo?.ToString("yyyy-MM-dd") ?? "" },
                                { "PageNumber", "1" },
                                { "PageSize", filters.PageSize.ToString() }
                            }">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                { "SearchTerm", filters.SearchTerm ?? "" },
                                { "OrderStatus", filters.OrderStatus?.ToString() ?? "" },
                                { "DateFrom", filters.DateFrom?.ToString("yyyy-MM-dd") ?? "" },
                                { "DateTo", filters.DateTo?.ToString("yyyy-MM-dd") ?? "" },
                                { "PageNumber", (Model.CurrentPage - 1).ToString() },
                                { "PageSize", filters.PageSize.ToString() }
                            }">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                { "SearchTerm", filters.SearchTerm ?? "" },
                                { "OrderStatus", filters.OrderStatus?.ToString() ?? "" },
                                { "DateFrom", filters.DateFrom?.ToString("yyyy-MM-dd") ?? "" },
                                { "DateTo", filters.DateTo?.ToString("yyyy-MM-dd") ?? "" },
                                { "PageNumber", i.ToString() },
                                { "PageSize", filters.PageSize.ToString() }
                            }">@i</a>
                        </li>
                    }

                    @if (Model.HasNextPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                { "SearchTerm", filters.SearchTerm ?? "" },
                                { "OrderStatus", filters.OrderStatus?.ToString() ?? "" },
                                { "DateFrom", filters.DateFrom?.ToString("yyyy-MM-dd") ?? "" },
                                { "DateTo", filters.DateTo?.ToString("yyyy-MM-dd") ?? "" },
                                { "PageNumber", (Model.CurrentPage + 1).ToString() },
                                { "PageSize", filters.PageSize.ToString() }
                            }">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-all-route-data="@new Dictionary<string, string>() {
                                { "SearchTerm", filters.SearchTerm ?? "" },
                                { "OrderStatus", filters.OrderStatus?.ToString() ?? "" },
                                { "DateFrom", filters.DateFrom?.ToString("yyyy-MM-dd") ?? "" },
                                { "DateTo", filters.DateTo?.ToString("yyyy-MM-dd") ?? "" },
                                { "PageNumber", Model.TotalPages.ToString() },
                                { "PageSize", filters.PageSize.ToString() }
                            }">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info">
            <h5><i class="bi bi-info-circle"></i> No Orders Yet</h5>
            <p class="mb-0">You haven't placed any orders yet. <a asp-controller="Catalog" asp-action="Index" class="alert-link">Start shopping</a></p>
        </div>
    }
</div>
