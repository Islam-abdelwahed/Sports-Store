@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mb-5">
    <div class="py-5">
        <i class="bi bi-shop-window" style="font-size: 4rem; color: #0d6efd;"></i>
        <h1 class="display-4 mt-3">Welcome to ECommerceStore</h1>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <p class="lead">Hello, <strong>@User.Identity.Name</strong>! Happy shopping! 🎉</p>
        }
        else
        {
            <p class="lead">Your one-stop shop for all your needs</p>
            <div class="mt-4">
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg me-2">
                    <i class="bi bi-person-plus"></i> Get Started
                </a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </a>
            </div>
        }
    </div>
</div>

<div class="row text-center mb-5">
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <i class="bi bi-cart-check text-primary" style="font-size: 3rem;"></i>
                <h3 class="card-title mt-3">Easy Shopping</h3>
                <p class="card-text">Browse our wide selection of products and add them to your cart with ease.</p>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-shop"></i> Start Shopping
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <i class="bi bi-truck text-success" style="font-size: 3rem;"></i>
                <h3 class="card-title mt-3">Fast Delivery</h3>
                <p class="card-text">We offer free shipping on all orders with fast and reliable delivery.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <i class="bi bi-shield-check text-info" style="font-size: 3rem;"></i>
                <h3 class="card-title mt-3">Secure Checkout</h3>
                <p class="card-text">Your payment information is encrypted and secure with our advanced technology.</p>
            </div>
        </div>
    </div>
</div>

<div class="text-center">
    <a asp-controller="Catalog" asp-action="Index" class="btn btn-success btn-lg">
        <i class="bi bi-arrow-right-circle"></i> View All Products
    </a>
</div>
