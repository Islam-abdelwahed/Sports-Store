@model Project.Models.ProductVM

@{
    ViewData["Title"] = Model.Name;
}

<div class="container">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.CategoryName</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="card-title mb-3">@Model.Name</h2>
                    <p class="text-muted mb-3">
                        <i class="bi bi-tag"></i> <strong>Category:</strong> @Model.CategoryName
                    </p>
                    <p class="mb-3">
                        <strong>SKU:</strong> <code>@Model.SKU</code>
                    </p>
                    
                    <hr />
                    
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h3 class="text-success mb-3">$@Model.Price.ToString("N2")</h3>
                        </div>
                        <div class="col-md-6 text-end">
                            @if (Model.StockQuantity > 0)
                            {
                                <span class="badge bg-success fs-6">
                                    <i class="bi bi-check-circle"></i> @Model.StockQuantity In Stock
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger fs-6">
                                    <i class="bi bi-x-circle"></i> Out of Stock
                                </span>
                            }
                        </div>
                    </div>

                    @if (Model.IsActive && Model.StockQuantity > 0)
                    {
                        <div class="alert alert-success mt-3">
                            <i class="bi bi-truck"></i> Available for immediate shipping
                        </div>
                    }
                    else if (!Model.IsActive)
                    {
                        <div class="alert alert-warning mt-3">
                            <i class="bi bi-exclamation-triangle"></i> This product is currently unavailable
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Purchase Options</h5>
                    
                    @if (Model.IsActive && Model.StockQuantity > 0)
                    {
                        <form asp-controller="Cart" asp-action="Add" method="post">
                            <input type="hidden" name="ProductId" value="@Model.ProductId" />
                            
                            <div class="mb-3">
                                <label for="quantity" class="form-label">Quantity</label>
                                <input type="number" class="form-control" id="quantity" name="Quantity" value="1" min="1" max="@Model.StockQuantity" />
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                </button>
                                <a asp-controller="Orders" asp-action="Checkout" asp-route-productId="@Model.ProductId" class="btn btn-primary">
                                    <i class="bi bi-lightning-charge"></i> Buy Now
                                </a>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            This product cannot be purchased at this time.
                        </div>
                    }

                    <hr class="my-3" />

                    <div class="d-grid">
                        <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Back to Category
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
