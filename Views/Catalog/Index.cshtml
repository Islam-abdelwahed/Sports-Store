@model Project.Models.ProductListVM

@{
    ViewData["Title"] = Model.CategoryName ?? "All Products";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-3">
                <i class="bi bi-shop"></i> @(Model.CategoryName ?? "All Products")
            </h2>
            @if (!string.IsNullOrEmpty(Model.CategoryName))
            {
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-action="Index">All Products</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@Model.CategoryName</li>
                    </ol>
                </nav>
            }
        </div>
    </div>

    <!-- Search Bar -->
    <form asp-action="Index" method="get" class="mb-4">
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-8">
                        <input type="text" name="searchTerm" class="form-control" placeholder="Search products by name or SKU..." value="@Model.SearchTerm" />
                        <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Search
                        </button>
                        @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                            <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="btn btn-secondary btn-sm mt-2 w-100">
                                <i class="bi bi-x"></i> Clear Search
                            </a>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <small class="text-muted mt-2 d-block">
                        <i class="bi bi-info-circle"></i>
                        Showing @Model.Products.Count result(s) for "<strong>@Model.SearchTerm</strong>"
                    </small>
                }
            </div>
        </div>
    </form>

    @if (Model.Products.Any())
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted small mb-2">
                                <i class="bi bi-tag"></i> @product.CategoryName
                            </p>
                            <p class="card-text small mb-2">
                                <strong>SKU:</strong> <code>@product.SKU</code>
                            </p>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="h5 mb-0 text-success">$@product.Price.ToString("N2")</span>
                                    @if (product.StockQuantity > 0)
                                    {
                                        <span class="badge bg-success">In Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Out of Stock</span>
                                    }
                                </div>
                                <div class="d-grid gap-2">
                                    <a asp-action="Details" asp-route-id="@product.ProductId" class="btn btn-primary btn-sm">
                                        <i class="bi bi-eye"></i> View Details
                                    </a>
                                    @if (product.StockQuantity > 0)
                                    {
                                        <form asp-controller="Cart" asp-action="Add" method="post" class="d-grid">
                                            <input type="hidden" name="productId" value="@product.ProductId" />
                                            <button type="submit" class="btn btn-success btn-sm">
                                                <i class="bi bi-cart-plus"></i> Add to Cart
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Product pagination" class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-categoryId="@Model.CategoryId" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No products found in this category.
        </div>
    }
</div>
